{
  "name": "@outblock/flow-dev-wallet-sdk",
  "version": "0.1.4",
  "description": "SDK for integrating Flow Dev Wallet into EVM dApps (wagmi/RainbowKit)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rainbowkit": {
      "types": "./dist/rainbowkit.d.ts",
      "import": "./dist/rainbowkit.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc"
  },
  "peerDependencies": {
    "wagmi": "latest"
  },
  "peerDependenciesMeta": {
    "wagmi": {
      "optional": true
    }
  },
  "keywords": ["flow", "evm", "wallet", "eip-1193", "rainbowkit", "wagmi", "dev-wallet"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Outblock/Flow-Dev-Wallet"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.95.2",
    "@wagmi/core": "^3.4.0",
    "viem": "^2.47.6",
    "wagmi": "^2.17.0"
  }
}
