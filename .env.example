# Flow Dev Wallet — Environment Variables
# Copy this file to .env and fill in your values.

# Lilico API key for account creation (server-side only, required for testnet/mainnet)
apikey=

# Default network: testnet | mainnet | emulator
network=testnet

# Payer service account (for pre-authz payer on testnet/mainnet)
payerPrivateKey=
payerAddress=
payerKeyIndex=0

# Emulator configuration
emulatorPrivateKey=
emulatorServiceAddress=0xf8d6e0586b0a20c7
emulatorAddress=http://localhost:8888
emulatorDiscoveryWallet=http://localhost:8701/fcl/authn

# FlowIndex API (optional, defaults to https://flowindex.io/api)
flowindexUrl=

# Wallet host URL (optional, defaults to http://localhost:3003)
host=http://localhost:3003
